{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Broker",
            "type": "shell",
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--release",
                "--bin",
                "broker"
            ],
            "group": {
                "kind": "build",
                //               "isDefault": true   
            }
        },
        {
            "label": "Pinger",
            "type": "shell",
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--release",
                "--bin",
                "pinger"
            ],
            "group": {
                "kind": "build",
                //               "isDefault": true   
            }
        },
        {
            "label": "Sniffer",
            "type": "shell",
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "sniffer"
            ],
            "group": {
                "kind": "build",
                //               "isDefault": true   
            }
        },
                {
            "label": "Codegen rust",
            "type": "shell",
            "command": "~/.cargo/bin/cargo", // note: full path to the cargo
            "args": [
                "run",
                "--bin",
                "codegen",
                "--",
                "-i",
                "hcl/robot.hcl",
                "-d",
                "hcl",
                "-t",
                "rust.tera",
                "-o",
                "generated/src/generated.rs"],
            "group": {
                "kind": "build",
                //               "isDefault": true   
            }
        },
                       {
            "label": "Codegen c++",
            "type": "shell",
            "command": "~/.cargo/bin/cargo", // note: full path to the cargo
            "args": [
                "run",
                "--bin",
                "codegen",
                "--",
                "-i",
                "hcl/robot.hcl",
                "-d",
                "hcl",
                "-t",
                "cpp.tera",
                "-o",
                "../esp32-eventbus/src/msgs.h"],
            "group": {
                "kind": "build",
                //               "isDefault": true   
            }
        },
        {
            "label": "ESP32 Eventbus",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/",
                }
            },
            "command": "~/.cargo/bin/cargo", // note: full path to the cargo
            "args": [
                "run",
                "--",
                "--input",
                "syntax/message.proto",
                "--output",
                "../esp32-eventbus/src",
                "--lang",
                "cpp",
                "--format",
                "cbor"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "clear": true // <-- this line
            }
        },

        {
